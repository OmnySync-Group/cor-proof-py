# Enforce consistent line endings across platforms
* text=auto

# Source/docs/config — LF always
*.py text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.toml text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary/archive/package artifacts — no line ending conversion
*.whl binary
*.gz binary
*.zip binary
